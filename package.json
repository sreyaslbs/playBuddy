{
  "name": "playbuddy-monorepo",
  "private": true,
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "web": "turbo run web",
    "build:web": "turbo run build --filter=@playbuddy/nextjs",
    "deploy:web": "npm run build:web && firebase deploy --only hosting",
    "firebase:login": "firebase login",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "@firebase/app": "0.14.9",
    "@firebase/auth": "1.12.1",
    "@firebase/auth-interop-types": "0.2.4",
    "@firebase/auth-types": "0.13.0",
    "@firebase/component": "0.7.1",
    "@firebase/database-types": "1.0.17",
    "@firebase/firestore": "4.12.0",
    "@firebase/firestore-types": "3.0.3",
    "@firebase/logger": "0.5.0",
    "@firebase/util": "1.14.0"
  }
}
